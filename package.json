{
  "name": "baby-infant-log",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "verify": "npm run check && npm test && npm run build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:setup": "npx supabase@latest db push",
    "db:setup:dry-run": "npx supabase@latest db push --dry-run",
    "db:wipe:test": "psql \"$SUPABASE_DB_URL\" --set ON_ERROR_STOP=on --file supabase/scripts/wipe-test-data.sql",
    "db:seed:test": "psql \"$SUPABASE_DB_URL\" --set ON_ERROR_STOP=on --file supabase/scripts/seed-30-day-newborn-ui-data.sql",
    "db:unseed:test": "psql \"$SUPABASE_DB_URL\" --set ON_ERROR_STOP=on --file supabase/scripts/remove-30-day-newborn-ui-data.sql"
  },
  "dependencies": {
    "@netlify/functions": "^5.3.0",
    "@supabase/supabase-js": "^2.110.2",
    "idb": "^8.0.3",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "svelte": "^5.56.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "svelte-check": "^4.7.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
