# Browser-safe Supabase values
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Optional Cloudflare Turnstile site key. Leave blank until CAPTCHA is enabled.
VITE_TURNSTILE_SITE_KEY=

# Netlify Function secrets (set in Netlify; never expose with VITE_ prefixes)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
INVITE_HMAC_SECRET=generate-a-long-random-secret

# Reusable transactional email transport for family invitations and future email flows
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_REPLY_TO=
PUBLIC_APP_URL=https://YOUR-PRODUCTION-DOMAIN
